# ============================================
# GymIQ Environment Variables
# Copy to .env and fill in values
# ============================================

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/gymiq_dev"

# OpenAI (GPT-4o-mini for member comms)
OPENAI_API_KEY="sk-..."

# Anthropic (Claude Sonnet for churn/cancel-save)
ANTHROPIC_API_KEY="sk-ant-..."

# Twilio (WhatsApp + SMS)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_WEBHOOK_URL="https://your-domain.com/webhooks/twilio"

# Redis (BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# API
PORT=3001
NODE_ENV="development"

# Auth (NextAuth)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="gymiq-uploads"
